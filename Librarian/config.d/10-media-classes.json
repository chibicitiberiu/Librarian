{
  "//": "Media-class detection. A detected content MIME (file --mime-type / Tika) wins when present; the extension lists are the fallback. Merged into the Classification options at startup; AppDataDirectory/config.d can override.",
  "Classification": {
    "VideoExtensions": [
      ".mkv", ".mp4", ".avi", ".mov", ".m4v", ".webm", ".wmv", ".flv", ".mpg", ".mpeg",
      ".m2ts", ".mts", ".ts", ".vob", ".ogv", ".3gp", ".divx", ".rm", ".rmvb", ".asf"
    ],
    "AudioExtensions": [
      ".flac", ".mp3", ".m4a", ".aac", ".ogg", ".oga", ".opus", ".wav", ".wma", ".alac", ".ape", ".wv"
    ],
    "ImageExtensions": [
      ".jpg", ".jpeg", ".png", ".gif", ".bmp", ".webp", ".tiff", ".tif"
    ],
    "ExecutableExtensions": [ ".exe", ".msi", ".com" ],

    "VideoMimePrefixes": [ "video/" ],
    "AudioMimePrefixes": [ "audio/" ],
    "ImageMimePrefixes": [ "image/" ]
  }
}
