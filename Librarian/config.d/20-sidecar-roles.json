    "ArtStems": [
      "cover", "folder", "backdrop", "logo", "poster", "fanart", "banner",
      "front", "back", "thumb", "thumbnail", "albumart", "albumartsmall", "disc"
    ],
    "SubtitleExtensions": [
      ".srt", ".sub", ".idx", ".ass", ".ssa", ".vtt", ".smi", ".sami", ".sup", ".ttml"
    ],
    "ResourceExtensions": [
