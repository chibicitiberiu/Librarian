{
  //"BaseDirectory": "Y:\\Library"
  "BaseDirectory": "/mnt/c/Temp/MediaLibrary",
  "AppDataDirectory": "data",
  "Languages": [ "english", "romanian" ],

  "ConnectionStrings": {
    "DB": "Database=postgres;Host=10.0.0.10;Port=5555;Username=postgres;Password=secretpassword123;Include Error Detail=true"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "Librarian": "Information"
    }
  },

  "Indexing": {
    // File containing a list of patterns to ignore. Uses .gitignore syntax.
    // Path can be absolute or relative to the AppDataDirectory
    "IgnoreListFile": "",

    // If set to true, all the indexed information about the file will be deleted from the database.
    "RemoveIndexOnDelete": "false"
  },

  // Resilience policy for metadata-provider calls during indexing (all optional; defaults shown).
  // Transient failures (network/timeout/5xx) are retried with exponential backoff; a provider that
  // keeps failing trips a circuit breaker for CircuitResetSeconds. Files whose extraction is cut
  // short are flagged and can be retried via POST /api/metadata/reindex-incomplete.
  "Metadata": {
    "MaxRetries": "2",
    "RetryBaseDelayMs": "500",
    "CircuitFailureThreshold": "5",
    "CircuitResetSeconds": "300"
  },

  "AllowedHosts": "*",

  "MetadataCliPath": "/home/tibi/.vs/meta-cli/out/build/linux-debug/meta-cli",

  // Path to Phil Harvey's exiftool binary, used to augment Tika with deeper embedded
  // image/media metadata (EXIF/IPTC/XMP/GPS/maker-notes/RAW). Defaults to resolving
  // "exiftool" on PATH; leave as-is if it is installed system-wide. Its absence is non-fatal.
  "ExifToolPath": "exiftool",

  // URL of an Apache Tika server (https://tika.apache.org) used for broad-format
  // metadata/content extraction. Leave empty to disable Tika.
  "TikaUrl": "http://localhost:9998",

  // Tika recursively unpacks archives/containers; cap how many embedded entries (e.g. files inside a
  // .zip) we keep metadata for, so a huge archive doesn't flood the raw layer. 0 = unlimited.
  "TikaMaxEmbeddedResources": "100",
}
