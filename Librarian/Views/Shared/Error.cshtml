@model ErrorViewModel
@{
    Layout = "_WmLayout";
    ViewData["Title"] = $"{Model.StatusCode} — {Model.Title}";
    ViewData["TaskbarActive"] = "browse";
}
<wm-window title="@Model.StatusCode @Model.Title" icon="/icons/16/file-manager.png">
    <div class="wm-locationbar-row">
        <wm-breadcrumb>
            <wm-crumb href="@Url.Action("Index", "Browse", new { path = "" })" icon="/icons/16/go-home.png" text="Home"></wm-crumb>
            <wm-crumb text="Error @Model.StatusCode"></wm-crumb>
        </wm-breadcrumb>
    </div>
    <div class="wm-window-body">
        <partial name="_WmSidebar" />
        <wm-content>
            <div class="wm-page">
                <div class="wm-section">
                    <div class="wm-error-code">@Model.StatusCode</div>
                    <div class="wm-section-heading">@Model.Title</div>
                    <p>@Model.Description</p>

                    <p style="margin-top:14px;">
                        <wm-button href="@Url.Action("Index", "Browse", new { path = "" })" icon="/icons/16/go-home.png" text="Back to the browser"></wm-button>
                    </p>

                    @if (Model.ShowRequestId)
                    {
                        <p class="muted" style="margin-top:14px;">
                            Request ID: <code>@Model.RequestId</code>
                        </p>
                    }
                </div>
            </div>
        </wm-content>
    </div>
    <wm-statusbar><span>@Model.StatusCode @Model.Title</span></wm-statusbar>
</wm-window>
