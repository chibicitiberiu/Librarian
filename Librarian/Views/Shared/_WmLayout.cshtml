@*
    Layout for the new window-manager chrome (lib/wm). The desktop hosts a single maximised window
    (rendered by the view via <wm-window>) above a fixed taskbar. No top nav bar — that goes away in
    the new design. Taskbar tray / live jobs are fleshed out in Phase E.
*@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Librarian</title>
    <meta name="description" content="" />
    <link rel="stylesheet" href="~/lib/wm/css/wm.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/wm/css/wm-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/wm-app.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <link rel="icon" href="~/favicon.ico" asp-append-version="true" />
</head>
<body class="wm-desktop">

    @RenderBody()

    @{ var taskbarActive = ViewData["TaskbarActive"] as string ?? "browse"; }
    <wm-taskbar>
        <wm-task icon="/icons/16/file-manager.png" text="Browse" href="@Url.Action("Index", "Browse", new { path = "" })"
                 active="@(taskbarActive == "browse")" tooltip="Browse the library"></wm-task>
        <wm-task icon="/icons/16/places/search.png" text="Search" href="@Url.Action("Index", "Search")"
                 active="@(taskbarActive == "search")" tooltip="Search the library"></wm-task>
        <wm-task icon="/icons/16/gnome-searchtool.png" text="Settings" href="@Url.Action("Index", "Admin")"
                 active="@(taskbarActive == "settings")" tooltip="Settings and maintenance"></wm-task>
        <div class="wm-layout-fill"></div>
        <wm-tray>
            <span class="wm-tray-icon" id="wm-tray-jobs" title="Background jobs: idle">
                <img src="~/icons/16/gnome-searchtool.png" alt="Background jobs" />
                <span class="wm-tray-badge"></span>
            </span>
        </wm-tray>
    </wm-taskbar>

    <script>
        window.wm_url_jobs = "@Url.Action("GetJobsSummary", "Jobs")";
    </script>
    <script src="~/lib/wm/js/wm.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
