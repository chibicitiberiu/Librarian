@model Librarian.ViewModels.ItemFileRow
<li class="@(Model.IsCurrent ? "wm-current" : "")">
    <img src="@Model.IconUrl" alt="" />
    <a href="@Url.Action("Index", "Metadata", new { path = Model.Path })">@Model.Name</a>
    @if (Model.IsPrimary)
    {
        <span class="wm-badge wm-badge-primary" title="The Item's primary content file">primary</span>
    }
    @if (Model.InArchive)
    {
        <span class="wm-badge wm-badge-warn" title="This file lives inside an archive">in archive</span>
    }
    <span class="wm-layout-fill"></span>
    <a href="@Url.Action("Index", "Browse", new { path = Model.Path })" title="Open file">↗</a>
</li>
