@using Librarian.Utils
@model List<Librarian.Services.DuplicateSet>
@{
    Layout = "_WmLayout";
    ViewData["Title"] = "Duplicates";
    ViewData["TaskbarActive"] = "browse";
    ViewData["WmSidebarActive"] = "duplicates";
}

<wm-window title="Duplicates" icon="/icons/16/places/all.png">

    <div class="wm-locationbar-row">
        <wm-breadcrumb>
            <wm-crumb href="@Url.Action("Index", "Browse", new { path = "" })" icon="/icons/16/go-home.png" text="Home"></wm-crumb>
            <wm-crumb icon="/icons/16/places/all.png" text="Duplicates"></wm-crumb>
        </wm-breadcrumb>
    </div>

    <div class="wm-window-body">
        <partial name="_WmSidebar" />
        <wm-content>
            <div class="wm-page">
                @if (Model.Count == 0)
                {
                    <p class="muted">No duplicates found. Files that share identical content appear here once the
                        checksum pass has run in Dedup mode (<code>POST /api/metadata/checksum?mode=Dedup</code>).</p>
                }
                else
                {
                    @foreach (var set in Model)
                    {
                        <div class="wm-section">
                            <div class="wm-section-heading">
                                @set.Paths.Count copies · @HumanizeUtils.HumanizeSize(set.Size ?? 0)
                            </div>
                            <ul class="wm-list">
                                @foreach (var p in set.Paths)
                                {
                                    <li>
                                        <img src="~/icons/16/file-types/file-generic.png" alt="" />
                                        <a href="@Url.Action("Index", "Metadata", new { path = p })">@p</a>
                                        <span class="wm-layout-fill"></span>
                                        <a href="@Url.Action("Index", "Browse", new { path = p })" title="Open file">↗</a>
                                    </li>
                                }
                            </ul>
                            <p class="wm-hint">SHA-256: <code>@set.Hash</code></p>
                        </div>
                    }
                }
            </div>
        </wm-content>
    </div>

    <wm-statusbar>
        <span>@Model.Count duplicate set@(Model.Count == 1 ? "" : "s")</span>
    </wm-statusbar>
</wm-window>
