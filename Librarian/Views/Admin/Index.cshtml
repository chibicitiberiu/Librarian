@model Librarian.ViewModels.AdminViewModel
@{
    Layout = "_WmLayout";
    ViewData["Title"] = "Settings";
    ViewData["TaskbarActive"] = "settings";
    ViewData["WmSidebarActive"] = "settings";
}

<wm-window title="Settings" icon="/icons/16/gnome-searchtool.png">

    <div class="wm-locationbar-row">
        <wm-breadcrumb>
            <wm-crumb href="@Url.Action("Index", "Browse", new { path = "" })" icon="/icons/16/go-home.png" text="Home"></wm-crumb>
            <wm-crumb icon="/icons/16/gnome-searchtool.png" text="Settings"></wm-crumb>
        </wm-breadcrumb>
    </div>

    <div class="wm-window-body">
        <partial name="_WmSidebar" />
        <wm-content>
            <div class="wm-page">

                @if (!string.IsNullOrEmpty(Model.Message))
                {
                    <p class="wm-banner">@Model.Message</p>
                }

                @if (Model.JobRunning)
                {
                    <p class="wm-banner">A background job is running now: <strong>@Model.RunningJob</strong>. Watch the tray in the taskbar for progress.</p>
                }

                <div class="wm-section">
                    <div class="wm-section-heading">Library</div>
                    <table class="wm-data-table">
                        <tbody>
                            <tr><td>Last indexed</td><td class="num">@(Model.LastIndexed?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "never")</td></tr>
                            <tr><td>Indexed files</td><td class="num">@Model.TotalFiles</td></tr>
                            <tr><td>Needs updating</td><td class="num">@Model.NeedsUpdating</td></tr>
                            <tr><td>Incomplete extraction</td><td class="num">@Model.Incomplete</td></tr>
                            <tr><td>Items</td><td class="num">@Model.Items</td></tr>
                            <tr><td>Collections</td><td class="num">@Model.Collections</td></tr>
                            <tr><td>Duplicate sets</td><td class="num">@Model.DuplicateSets</td></tr>
                            <tr><td>Checksum mode</td><td class="num">@Model.ChecksumMode</td></tr>
                        </tbody>
                    </table>
                </div>

                <div class="wm-section">
                    <div class="wm-section-heading">Library directory</div>
                    <p class="wm-hint">The root folder Librarian indexes and browses. Changing it takes effect after a restart.</p>
                    <form method="post" asp-controller="Admin" asp-action="SaveLibraryDirectory">
                        <div class="wm-actions">
                            <input type="text" name="libraryDirectory" value="@Model.LibraryDirectory"
                                   class="wm-input wm-input-wide" style="min-width:360px;" spellcheck="false" autocomplete="off"
                                   placeholder="/path/to/your/library" />
                            <wm-button type="submit" icon="/icons/32/document-save.png" text="Save"></wm-button>
                        </div>
                    </form>
                    <p class="wm-hint">In effect this run: <code>@Model.LibraryDirectoryResolved</code></p>
                </div>

                <div class="wm-section">
                    <div class="wm-section-heading">Maintenance</div>
                    <p class="wm-hint">Each action runs now and may take a while on a large library; the page returns when it finishes. Start with <strong>Rebuild everything</strong> if the index looks wrong.</p>
                    <div class="wm-actions">
                        <form method="post" asp-controller="Admin" asp-action="RebuildAll">
                            <wm-button type="submit" icon="/icons/32/view-refresh.png" text="Rebuild everything" tooltip="Re-extract every file from scratch, then re-associate items/collections, renormalize and rebuild search"></wm-button>
                        </form>
                        <form method="post" asp-controller="Admin" asp-action="Reindex">
                            <wm-button type="submit" text="Reindex (incremental)" tooltip="Scan for changed files and re-group items"></wm-button>
                        </form>
                        <form method="post" asp-controller="Admin" asp-action="Reindex">
                            <input type="hidden" name="force" value="true" />
                            <wm-button type="submit" text="Re-extract all" tooltip="Re-extract every file from scratch — slow"></wm-button>
                        </form>
                        <form method="post" asp-controller="Admin" asp-action="ReindexIncomplete">
                            <wm-button type="submit" text="Reindex incomplete" tooltip="Retry files whose last extraction was cut short"></wm-button>
                        </form>
                        <form method="post" asp-controller="Admin" asp-action="Associate">
                            <wm-button type="submit" text="Associate items" tooltip="Re-group files into items and collections"></wm-button>
                        </form>
                        <form method="post" asp-controller="Admin" asp-action="Renormalize">
                            <wm-button type="submit" text="Renormalize" tooltip="Rebuild canonical attributes from stored raw metadata"></wm-button>
                        </form>
                        <form method="post" asp-controller="Admin" asp-action="ReindexSearch">
                            <wm-button type="submit" text="Rebuild search" tooltip="Rebuild full-text-search vectors"></wm-button>
                        </form>
                    </div>
                </div>

                <div class="wm-section">
                    <div class="wm-section-heading">Checksums &amp; dedup</div>
                    <form method="post" asp-controller="Admin" asp-action="Checksum">
                        <div class="wm-actions">
                            <select name="mode">
                                <option value="Dedup">Dedup (find duplicates)</option>
                                <option value="Integrity">Integrity (hash everything)</option>
                                <option value="Off">Off</option>
                            </select>
                            <wm-button type="submit" text="Run checksum pass"></wm-button>
                            <wm-button href="@Url.Action("Index", "Duplicates")" text="View duplicates"></wm-button>
                        </div>
                    </form>
                </div>

                <div class="wm-section">
                    <div class="wm-section-heading">Unmapped metadata keys (@Model.UnmappedTotal)</div>
                    @if (Model.UnmappedKeys.Count == 0)
                    {
                        <p class="muted">Every raw metadata key currently has a normalization rule.</p>
                    }
                    else
                    {
                        <p class="wm-hint">Most common raw keys with no canonical mapping — candidates for new rules.</p>
                        <table class="wm-data-table">
                            <thead>
                                <tr><th>Namespace</th><th>Key</th><th class="num">Count</th><th>Sample value</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var k in Model.UnmappedKeys)
                                {
                                    <tr>
                                        <td>@k.Namespace</td>
                                        <td>@k.Key</td>
                                        <td class="num">@k.Count</td>
                                        <td>@(k.SampleValue?.Length > 80 ? k.SampleValue[..80] + "…" : k.SampleValue)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>

            </div>
        </wm-content>
    </div>

    <wm-statusbar>
        <span>@Model.TotalFiles files · @Model.Items items · @Model.Collections collections</span>
    </wm-statusbar>
</wm-window>
