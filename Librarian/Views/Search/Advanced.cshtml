@{
    Layout = "_WmLayout";
    ViewData["Title"] = "Advanced search";
    ViewData["TaskbarActive"] = "search";
    ViewData["WmSidebarActive"] = "search";
}

<wm-window title="Advanced search" icon="/icons/16/places/search.png">

    <div class="wm-locationbar-row">
        <wm-breadcrumb>
            <wm-crumb href="@Url.Action("Index", "Browse", new { path = "" })" icon="/icons/16/go-home.png" text="Home"></wm-crumb>
            <wm-crumb href="@Url.Action("Index", "Search")" icon="/icons/16/places/search.png" text="Search"></wm-crumb>
            <wm-crumb text="Advanced"></wm-crumb>
        </wm-breadcrumb>
    </div>

    <div class="wm-window-body">
        <partial name="_WmSidebar" />
        <wm-content>
            <div class="wm-page">
                <div class="wm-section">
                    <div class="wm-section-heading">Advanced search</div>
                    <p class="wm-hint">Search file contents and metadata, optionally limited to a folder.</p>

                    <form method="get" asp-controller="Search" asp-action="Index">
                        <label class="wm-field">
                            <span class="wm-field-label">Query</span>
                            <input class="wm-input wm-input-wide" type="search" name="query"
                                   placeholder="Words to look for…" autofocus />
                        </label>

                        <label class="wm-field">
                            <span class="wm-field-label">Within folder</span>
                            <input class="wm-input wm-input-wide" type="text" name="path"
                                   placeholder="e.g. music/albums (optional)" />
                        </label>

                        <div class="wm-field">
                            <span class="wm-field-label">Search in</span>
                            @* Checkbox first, hidden "false" companion after, so an unchecked box binds to false. *@
                            <label class="wm-field-inline">
                                <input type="checkbox" name="include_content" value="true" checked />
                                content
                            </label>
                            <input type="hidden" name="include_content" value="false" />

                            <label class="wm-field-inline">
                                <input type="checkbox" name="include_metadata" value="true" checked />
                                metadata
                            </label>
                            <input type="hidden" name="include_metadata" value="false" />
                        </div>

                        <div class="wm-actions">
                            <wm-button type="submit" icon="/icons/32/gnome-searchtool.png" text="Search"></wm-button>
                            <wm-button href="@Url.Action("Index", "Search")" text="Back to search"></wm-button>
                        </div>
                    </form>
                </div>
            </div>
        </wm-content>
    </div>

    <wm-statusbar>
        <span class="muted">Advanced search</span>
    </wm-statusbar>
</wm-window>
