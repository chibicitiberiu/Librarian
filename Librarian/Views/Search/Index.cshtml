@model Librarian.ViewModels.SearchViewModel
@{
    Layout = "_WmLayout";
    ViewData["Title"] = string.IsNullOrWhiteSpace(Model.Query) ? "Search" : $"Search: {Model.Query}";
    ViewData["TaskbarActive"] = "search";
    ViewData["WmSidebarActive"] = "search";

    string? ParentPath(string path)
    {
        int slash = path.LastIndexOf('/');
        return slash > 0 ? path[..slash] : null;
    }

    string PageUrl(int page) => Url.Action("Index", "Search", new
    {
        query = Model.Query,
        include_content = Model.IncludeContent,
        include_metadata = Model.IncludeMetadata,
        path = Model.PathPrefix,
        page,
    })!;
}

<wm-window title="Search" icon="/icons/16/places/search.png">

    <wm-toolbar>
        <form method="get" asp-controller="Search" asp-action="Index">
            <span class="wm-toolbar-field">
                <input type="search" name="query" value="@Model.Query"
                       placeholder="Search content and metadata…" autofocus />
            </span>

            @if (!string.IsNullOrWhiteSpace(Model.PathPrefix))
            {
                <input type="hidden" name="path" value="@Model.PathPrefix" />
            }

            @* Checkbox first, hidden "false" companion after, so an unchecked box binds to false. *@
            <label class="wm-field-inline">
                <input type="checkbox" name="include_content" value="true" checked="@Model.IncludeContent" />
                in content
            </label>
            <input type="hidden" name="include_content" value="false" />

            <label class="wm-field-inline">
                <input type="checkbox" name="include_metadata" value="true" checked="@Model.IncludeMetadata" />
                in metadata
            </label>
            <input type="hidden" name="include_metadata" value="false" />

            <wm-button type="submit" icon="/icons/32/gnome-searchtool.png" text="Search"></wm-button>
            <wm-button href="@Url.Action("Advanced", "Search")" text="Advanced"></wm-button>
        </form>
    </wm-toolbar>

    <div class="wm-locationbar-row">
        <wm-breadcrumb>
            <wm-crumb href="@Url.Action("Index", "Browse", new { path = "" })" icon="/icons/16/go-home.png" text="Home"></wm-crumb>
            <wm-crumb icon="/icons/16/places/search.png" text="Search"></wm-crumb>
        </wm-breadcrumb>
    </div>

    <div class="wm-window-body">
        <partial name="_WmSidebar" />
        <wm-content>
            <div class="wm-page">

                @if (Model.Results is null)
                {
                    <p class="wm-hint">Enter a query to search file contents and metadata.</p>
                }
                else if (Model.Results.TotalCount == 0)
                {
                    <p class="wm-hint">No results for <strong>@Model.Query</strong>.</p>
                }
                else
                {
                    <p class="muted">
                        @Model.Results.TotalCount result@(Model.Results.TotalCount == 1 ? "" : "s")
                        — page @Model.Results.Page of @Model.Results.TotalPages
                    </p>

                    @foreach (var result in Model.Results.Results)
                    {
                        var parent = ParentPath(result.Path);
                        <div class="wm-result">
                            <div class="wm-result-title">
                                @* Url.Action routes through the {**path} catch-all, which URL-encodes
                                   special characters (#, ?, %, spaces) while preserving slashes. *@
                                <a href="@Url.Action("Index", "Metadata", new { path = result.Path })">@result.Name</a>
                                @if (result.InContent)
                                {
                                    <span class="wm-badge">content</span>
                                }
                                @if (result.InMetadata)
                                {
                                    <span class="wm-badge">metadata</span>
                                }
                            </div>
                            <div class="wm-result-path">
                                @if (parent is not null)
                                {
                                    <a href="@Url.Action("Index", "Browse", new { path = parent })">@parent/</a>
                                }
                                else
                                {
                                    <a href="@Url.Action("Index", "Browse", new { path = "" })">/</a>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(result.Snippet))
                            {
                                <div class="wm-result-snippet">@Html.Raw(result.Snippet)</div>
                            }
                        </div>
                    }

                    @if (Model.Results.TotalPages > 1)
                    {
                        <div class="wm-pager">
                            @if (Model.Results.HasPrevious)
                            {
                                <wm-button href="@PageUrl(Model.Results.Page - 1)" text="« Previous"></wm-button>
                            }
                            <span class="wm-layout-fill"></span>
                            @if (Model.Results.HasNext)
                            {
                                <wm-button href="@PageUrl(Model.Results.Page + 1)" text="Next »"></wm-button>
                            }
                        </div>
                    }
                }

            </div>
        </wm-content>
    </div>

    <wm-statusbar>
        @if (Model.Results is null)
        {
            <span class="muted">Enter a query to search.</span>
        }
        else if (Model.Results.TotalCount == 0)
        {
            <span>No matches</span>
        }
        else
        {
            <span>@Model.Results.TotalCount match@(Model.Results.TotalCount == 1 ? "" : "es") · page @Model.Results.Page of @Model.Results.TotalPages</span>
        }
    </wm-statusbar>
</wm-window>
