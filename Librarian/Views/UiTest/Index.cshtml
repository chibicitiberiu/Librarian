@using Librarian.ViewModels
@using Microsoft.AspNetCore.Routing
@model UiTestViewModel
@{
    Layout = "_WmLayout";
    ViewData["Title"] = Model.DisplayName;
    ViewData["WmSidebarActive"] = "home";

    var isRoot = Model.Path == ".";
    var pathArg = isRoot ? "" : Model.Path;
    var folderProps = isRoot ? null : $"{Url.Action("Index", "Metadata")}/{Model.Path}";
    var upUrl = Model.ParentPath != null ? Url.Action("Index", "UiTest", new { path = Model.ParentPath }) : null;

    // View-state changes carry a single explicit param; the controller saves it to a cookie and
    // redirects back to the clean (param-free) URL. CleanUrl is that folder URL (used for Refresh).
    string CleanUrl() => Url.Action("Index", "UiTest", new { path = pathArg })!;
    string SetUrl(string key, string val) =>
        Url.Action("Index", "UiTest", new RouteValueDictionary { ["path"] = pathArg, [key] = val })!;

    bool ModeIs(string m) => Model.Mode == m;
    bool SortIs(string s) => Model.Sort == s;
    bool isDetails = ModeIs("details");
}

<wm-window title="@Model.DisplayName" icon="/icons/16/file-manager.png">

    <wm-menubar>
        <wm-menu text="File" tooltip="Actions for the selected item(s)">
            <wm-menuitem icon="/icons/32/edit-cut.png" text="Cut" action="cut" data-wm-needs-selection tooltip="Cut selection"></wm-menuitem>
            <wm-menuitem icon="/icons/32/edit-copy.png" text="Copy" action="copy" data-wm-needs-selection tooltip="Copy selection"></wm-menuitem>
            <wm-menuitem icon="/icons/32/edit-paste.png" text="Paste" action="paste" disabled="true" tooltip="Paste"></wm-menuitem>
            <wm-menu-separator></wm-menu-separator>
            <wm-menuitem icon="/icons/32/edit.png" text="Rename" action="rename" data-wm-needs-selection tooltip="Rename"></wm-menuitem>
            <wm-menuitem icon="/icons/32/edit-delete.png" text="Delete" action="delete" data-wm-needs-selection tooltip="Delete"></wm-menuitem>
            <wm-menu-separator></wm-menu-separator>
            <wm-menuitem icon="/icons/32/gnome-stock-insert-table.png" text="Properties" action="properties" data-wm-needs-selection tooltip="Properties of the selection"></wm-menuitem>
        </wm-menu>

        <wm-menu text="Folder" tooltip="Actions for the current folder">
            <wm-menuitem icon="/icons/16/go-up.png" text="Open parent" href="@(Model.ParentPath != null ? Url.Action("Index", "UiTest", new { path = Model.ParentPath }) : null)" disabled="@(Model.ParentPath == null)" tooltip="Go to the parent folder"></wm-menuitem>
            <wm-menuitem text="Refresh" href="@CleanUrl()" tooltip="Reload this folder"></wm-menuitem>
            <wm-menu-separator></wm-menu-separator>
            <wm-menuitem text="Paste" action="paste" disabled="true" tooltip="Paste into this folder"></wm-menuitem>
            <wm-menuitem text="New folder…" action="newfolder" disabled="true" tooltip="Create a folder (coming soon)"></wm-menuitem>
            <wm-menu-separator></wm-menu-separator>
            <wm-menuitem icon="/icons/32/gnome-stock-insert-table.png" text="Properties" href="@folderProps" disabled="@isRoot" tooltip="Folder metadata"></wm-menuitem>
        </wm-menu>

        <wm-menu text="View">
            <wm-menuitem text="View mode">
                <wm-menuitem text="Details" checked="@ModeIs("details")" href="@SetUrl("view", "details")" tooltip="Details (sortable table)"></wm-menuitem>
                <wm-menuitem text="List" checked="@ModeIs("list")" href="@SetUrl("view", "list")" tooltip="List"></wm-menuitem>
                <wm-menuitem text="Tiles" checked="@ModeIs("tiles")" href="@SetUrl("view", "tiles")" tooltip="Tiles"></wm-menuitem>
                <wm-menuitem text="Icons" checked="@ModeIs("icons")" href="@SetUrl("view", "icons")" tooltip="Icons"></wm-menuitem>
            </wm-menuitem>
            <wm-menuitem text="Sort by">
                <wm-menuitem text="Name" checked="@SortIs("name")" href="@SetUrl("sort", "name")" tooltip="Sort by name"></wm-menuitem>
                <wm-menuitem text="Size" checked="@SortIs("size")" href="@SetUrl("sort", "size")" tooltip="Sort by size"></wm-menuitem>
                <wm-menuitem text="Type" checked="@SortIs("type")" href="@SetUrl("sort", "type")" tooltip="Sort by type"></wm-menuitem>
                <wm-menuitem text="Modified" checked="@SortIs("modified")" href="@SetUrl("sort", "modified")" tooltip="Sort by last modified"></wm-menuitem>
            </wm-menuitem>
            <wm-menuitem text="Zoom">
                <wm-menuitem text="Small" checked="@(Model.Zoom == 1)" href="@SetUrl("zoom", "1")" disabled="@isDetails" tooltip="Small icons"></wm-menuitem>
                <wm-menuitem text="Medium" checked="@(Model.Zoom == 2)" href="@SetUrl("zoom", "2")" disabled="@isDetails" tooltip="Medium icons"></wm-menuitem>
                <wm-menuitem text="Large" checked="@(Model.Zoom == 3)" href="@SetUrl("zoom", "3")" disabled="@isDetails" tooltip="Large icons"></wm-menuitem>
            </wm-menuitem>
            <wm-menu-separator></wm-menu-separator>
            <wm-menuitem checkbox="true" checked="@Model.ShowHidden" text="Show hidden" href="@SetUrl("hidden", Model.ShowHidden ? "false" : "true")" tooltip="Show hidden files"></wm-menuitem>
            <wm-menuitem checkbox="true" checked="@Model.ItemView" text="Item view" href="@SetUrl("itemview", Model.ItemView ? "false" : "true")" tooltip="Group files into items"></wm-menuitem>
        </wm-menu>

        <wm-menu text="Help">
            <wm-menuitem icon="/icons/16/gnome-searchtool.png" text="About Librarian…" action="about" data-wm-open-modal="modal-about" tooltip="About this application"></wm-menuitem>
        </wm-menu>
    </wm-menubar>

    <wm-toolbar>
        <wm-button icon="/icons/32/edit-cut.png" text="Cut" tooltip="Cut selection" data-wm-needs-selection></wm-button>
        <wm-button icon="/icons/32/edit-copy.png" text="Copy" tooltip="Copy selection" data-wm-needs-selection></wm-button>
        <wm-button icon="/icons/32/edit-paste.png" text="Paste" tooltip="Paste into this folder" disabled="true"></wm-button>
        <wm-separator></wm-separator>
        <wm-button icon="/icons/32/edit.png" text="Rename" tooltip="Rename" data-wm-needs-selection></wm-button>
        <wm-button icon="/icons/32/edit-delete.png" text="Delete" tooltip="Delete" data-wm-needs-selection></wm-button>
        <wm-separator></wm-separator>
        <wm-button icon="/icons/32/gnome-stock-insert-table.png" text="Metadata" tooltip="View metadata" data-wm-needs-selection></wm-button>

        <div class="wm-layout-fill"></div>

        <wm-button icon="/icons/32/views/details.png" text="Details" href="@SetUrl("view", "details")" disabled="@ModeIs("details")" tooltip="Details view"></wm-button>
        <wm-button icon="/icons/32/views/list.png" text="List" href="@SetUrl("view", "list")" disabled="@ModeIs("list")" tooltip="List view"></wm-button>
        <wm-button icon="/icons/32/views/tiles.png" text="Tiles" href="@SetUrl("view", "tiles")" disabled="@ModeIs("tiles")" tooltip="Tile view"></wm-button>
        <wm-button icon="/icons/32/views/icons.png" text="Icons" href="@SetUrl("view", "icons")" disabled="@ModeIs("icons")" tooltip="Icon view"></wm-button>
        <wm-separator></wm-separator>
        <wm-button icon="/icons/32/views/zoom-out.png" href="@SetUrl("zoom", (Model.Zoom - 1).ToString())" disabled="@(isDetails || Model.Zoom <= 1)" tooltip="Zoom out"></wm-button>
        <wm-button icon="/icons/32/views/zoom-in.png" href="@SetUrl("zoom", (Model.Zoom + 1).ToString())" disabled="@(isDetails || Model.Zoom >= 3)" tooltip="Zoom in"></wm-button>
    </wm-toolbar>

    <div class="wm-locationbar-row">
        <wm-button class="wm-locationbar-up" icon="/icons/16/go-up.png" text="Up" href="@upUrl" disabled="@(Model.ParentPath == null)" tooltip="Up to the parent folder"></wm-button>
        <wm-breadcrumb>
            <wm-crumb href="@Url.Action("Index", "UiTest", new { path = "" })" icon="/icons/16/go-home.png" text="Home"></wm-crumb>
            @foreach (var (name, p) in Model.Breadcrumbs)
            {
                <wm-crumb href="@Url.Action("Index", "UiTest", new { path = p })" text="@name"></wm-crumb>
            }
        </wm-breadcrumb>
    </div>

    <div class="wm-window-body">
        <partial name="_WmSidebar" />
        <wm-content data-wm-contextmenu="uitest-filemenu" data-wm-contextmenu-empty="uitest-foldermenu">
            <wm-filelist mode="@Model.Mode" zoom="@Model.Zoom" items="Model.Items" columns="Model.Columns"
                         selectable="true" show-checkboxes="true"></wm-filelist>
        </wm-content>
    </div>

    <wm-statusbar>
        <span>@Model.Count item@(Model.Count == 1 ? "" : "s")</span>
        <span class="wm-layout-fill"></span>
        <span class="muted" data-wm-selection-count></span>
    </wm-statusbar>
</wm-window>

@* Right-click menu for the file list. JS positions it at the cursor and auto-selects the row. *@
<wm-contextmenu id="uitest-filemenu" data-properties-url="/metadata">
    <wm-menuitem icon="/icons/16/file-manager.png" text="Open" action="open" tooltip="Open"></wm-menuitem>
    <wm-menuitem icon="/icons/32/gnome-stock-insert-table.png" text="Properties" action="properties" tooltip="View metadata"></wm-menuitem>
    <wm-menu-separator></wm-menu-separator>
    <wm-menuitem text="Cut" action="cut" disabled="true" tooltip="Cut (coming soon)"></wm-menuitem>
    <wm-menuitem text="Copy" action="copy" disabled="true" tooltip="Copy (coming soon)"></wm-menuitem>
    <wm-menuitem text="Delete" action="delete" disabled="true" tooltip="Delete (coming soon)"></wm-menuitem>
</wm-contextmenu>

@* Right-click on empty space → folder actions (no item under the cursor). *@
<wm-contextmenu id="uitest-foldermenu">
    <wm-menuitem text="Paste" action="paste" disabled="true" tooltip="Paste into this folder"></wm-menuitem>
    <wm-menuitem text="New folder…" action="newfolder" disabled="true" tooltip="Create a folder (coming soon)"></wm-menuitem>
    <wm-menu-separator></wm-menu-separator>
    <wm-menuitem text="Refresh" href="@CleanUrl()" tooltip="Reload this folder"></wm-menuitem>
    <wm-menu-separator></wm-menu-separator>
    <wm-menuitem icon="/icons/32/gnome-stock-insert-table.png" text="Properties" href="@folderProps" disabled="@isRoot" tooltip="Folder metadata"></wm-menuitem>
</wm-contextmenu>

@* Help → About — exercises the modal control (dim backdrop, X button, OK action, grayscale title bar on the window behind). *@
<wm-modal id="modal-about" title="About Librarian" icon="/icons/16/file-manager.png" ok-text="OK">
    <p style="margin-top:0;"><strong>Librarian</strong> — a retro-styled media library browser.</p>
    <p>This page (<code>/uitest</code>) is a live sandbox for the new <em>window-manager</em> control
        library: window chrome, menus, toolbar, breadcrumb, file list and this modal, all rendered
        server-side (Tier-0) and enhanced with a little JavaScript.</p>
    <p class="muted" style="margin-bottom:0;">Built with Razor tag helpers over the <code>lib/wm</code> Bluecurve theme.</p>
</wm-modal>
