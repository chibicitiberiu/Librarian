# Normalize line endings: store as LF in the repo, check out LF on all platforms.
* text=auto eol=lf

# Source / text files (explicit for clarity)
*.cs        text eol=lf
*.csproj    text eol=lf
*.sln       text eol=lf
*.cshtml    text eol=lf
*.razor     text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.config    text eol=lf
*.resx      text eol=lf
*.tt        text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.html      text eol=lf
*.md        text eol=lf
*.cpp       text eol=lf
*.h         text eol=lf
*.cmake     text eol=lf
CMakeLists.txt text eol=lf

# Windows-only scripts must keep CRLF to run correctly
*.cmd       text eol=crlf
*.bat       text eol=crlf
*.ps1       text eol=crlf

# Binary assets — never touch
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.bmp       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.dll       binary
*.exe       binary
*.so        binary
